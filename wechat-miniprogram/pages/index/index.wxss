.page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 28px 24px 40px;
  background: #f7fbff;
}

.home-screen,
.plain-screen,
.win-screen {
  min-height: 82vh;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.brand {
  margin-bottom: 56px;
}

.brand-title,
.screen-title,
.win-title {
  color: #152238;
  font-size: 44px;
  font-weight: 800;
  line-height: 1.15;
}

.brand-subtitle,
.win-subtitle {
  margin-top: 18px;
  color: #4b5563;
  font-size: 26px;
  line-height: 1.35;
}

.home-actions,
.difficulty-list {
  display: flex;
  flex-direction: column;
  gap: 22px;
}

.big-button,
.difficulty-button,
.tool-button {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 72px;
  border-radius: 8px;
  font-size: 28px;
  font-weight: 700;
  line-height: 1.2;
}

.primary-button {
  background: #2563eb;
  color: #ffffff;
  box-shadow: 0 8px 0 #1d4ed8;
}

.secondary-button {
  background: #ffffff;
  color: #1f2937;
  border: 4px solid #c7d2fe;
}

.light-button {
  margin-top: 30px;
  background: #ffffff;
  color: #1f2937;
  border: 4px solid #cbd5e1;
}

.difficulty-button {
  justify-content: space-between;
  min-height: 86px;
  padding: 0 28px;
  background: #ffffff;
  border: 4px solid #d1d5db;
  color: #1f2937;
}

.difficulty-button-active {
  border-color: #2563eb;
  background: #dbeafe;
}

.difficulty-name {
  font-size: 30px;
}

.difficulty-size {
  color: #374151;
  font-size: 24px;
}

.rules-text {
  display: flex;
  flex-direction: column;
  gap: 20px;
  margin: 34px 0 28px;
  color: #1f2937;
  font-size: 28px;
  line-height: 1.55;
}

.game-screen {
  display: flex;
  flex-direction: column;
  gap: 16px;
}

.game-status {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 10px;
}

.status-box {
  min-height: 76px;
  padding: 10px 8px;
  border-radius: 8px;
  background: #ffffff;
  border: 3px solid #d9e7f7;
  box-sizing: border-box;
  text-align: center;
}

.status-label {
  display: block;
  color: #4b5563;
  font-size: 20px;
  line-height: 1.2;
}

.status-value {
  display: block;
  margin-top: 6px;
  color: #111827;
  font-size: 26px;
  font-weight: 800;
  line-height: 1.15;
}

.game-actions {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 10px;
}

.tool-button {
  min-height: 66px;
  padding: 0 8px;
  font-size: 24px;
}

.hint-button {
  background: #16a34a;
  color: #ffffff;
}

.restart-button {
  background: #f59e0b;
  color: #111827;
}

.home-button {
  background: #ffffff;
  color: #1f2937;
  border: 3px solid #cbd5e1;
}

.message-bar {
  min-height: 50px;
  padding: 10px 14px;
  border-radius: 8px;
  background: #eef6ff;
  color: #12315a;
  border: 3px solid #bfdbfe;
  box-sizing: border-box;
  font-size: 23px;
  font-weight: 700;
  line-height: 1.3;
}

.board-scroll {
  width: 100%;
  height: 62vh;
  min-height: 430px;
  border-radius: 8px;
  background: #edf7f1;
  border: 4px solid #b7dbc4;
  box-sizing: border-box;
}

.board {
  position: relative;
  box-sizing: border-box;
}

.path-line {
  position: absolute;
  z-index: 20;
  border-radius: 999px;
  background: #dc2626;
  box-shadow: 0 0 0 4px rgba(255, 255, 255, 0.88);
}

.tile {
  position: absolute;
  z-index: 10;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  border-radius: 8px;
  border: 4px solid rgba(17, 24, 39, 0.2);
  box-sizing: border-box;
  color: #111827;
  box-shadow: 0 5px 0 rgba(17, 24, 39, 0.18);
}

.tile-icon {
  display: block;
  font-size: 40px;
  line-height: 1;
}

.tile-hover {
  transform: scale(0.98);
}

.tile-selected {
  z-index: 25;
  border-color: #dc2626;
  box-shadow: 0 0 0 7px rgba(220, 38, 38, 0.28), 0 5px 0 rgba(17, 24, 39, 0.18);
}

.tile-hint {
  z-index: 24;
  border-color: #2563eb;
  box-shadow: 0 0 0 7px rgba(37, 99, 235, 0.24), 0 5px 0 rgba(17, 24, 39, 0.18);
}

.tile-removed {
  opacity: 0;
  pointer-events: none;
}

.tone-0 {
  background: #fde68a;
}

.tone-1 {
  background: #fecdd3;
}

.tone-2 {
  background: #bfdbfe;
}

.tone-3 {
  background: #c7d2fe;
}

.tone-4 {
  background: #bbf7d0;
}

.tone-5 {
  background: #fed7aa;
}

.tone-6 {
  background: #bae6fd;
}

.tone-7 {
  background: #ddd6fe;
}

.tone-8 {
  background: #fbcfe8;
}

.tone-9 {
  background: #ccfbf1;
}

.win-screen {
  align-items: stretch;
}

.win-title {
  font-size: 54px;
}

.win-time {
  margin: 26px 0 38px;
  color: #1f2937;
  font-size: 30px;
  font-weight: 800;
  line-height: 1.3;
}
